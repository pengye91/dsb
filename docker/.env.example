# docker/.env.example
# Standard International Configuration
DOCKER_REGISTRY=docker.io
PYPI_MIRROR=https://pypi.org/simple
NPM_MIRROR=https://registry.npmjs.org
CARGO_REGISTRY=https://index.crates.io
DEBIAN_MIRROR=deb.debian.org
# Rust toolchain: dist root (rustc/std) and rustup self-update root — must not use .../rustup for DIST_SERVER
RUSTUP_DIST_SERVER=https://static.rust-lang.org
RUSTUP_UPDATE_ROOT=https://static.rust-lang.org/rustup

# Standard Service Ports (can be overridden)
DSB_SERVER_PORT=8080
DSB_DASHBOARD_PORT=3001
DSB_SSH_GATEWAY_PORT=2223
DSB_SEARXNG_PORT=8888
DSB_MCP_PORT=3000

# SearXNG secret key for session encryption. Generate with: openssl rand -hex 24
SEARXNG_SECRET=
