# Quick build DSB Test Server — no cargo-chef, for test infrastructure
ARG DOCKER_REGISTRY=docker.io
ARG BASE_IMAGE_TAG=latest

FROM dsb/rust-base:${BASE_IMAGE_TAG} AS builder
WORKDIR /build

COPY . .

# Build with dev-build profile using BuildKit cache mount for incremental compilation.
RUN --mount=type=cache,target=/build/target \
    cargo build --profile dev-build --bin dsb --features kubernetes && \
    cp /build/target/dev-build/dsb /usr/local/bin/dsb

FROM dsb/runtime-base:${BASE_IMAGE_TAG}

COPY --from=builder /usr/local/bin/dsb /usr/local/bin/dsb

RUN mkdir -p /var/lib/dsb/static-files && \
    chown -R dsb:dsb /var/lib/dsb

USER root
WORKDIR /home/dsb

EXPOSE 8080

HEALTHCHECK --interval=1s --timeout=2s --retries=15 --start-period=3s \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["dsb", "server"]
