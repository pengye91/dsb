# syntax=docker/dockerfile:1
ARG DOCKER_REGISTRY=docker.io
FROM ${DOCKER_REGISTRY}/node:20.14.0-alpine as builder

ARG NPM_MIRROR=https://registry.npmjs.org

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies with optional mirror
RUN --mount=type=cache,target=/root/.npm \
    if [ "${NPM_MIRROR}" != "https://registry.npmjs.org" ]; then \
        npm config set registry ${NPM_MIRROR}; \
    fi && \
    npm ci --legacy-peer-deps

# Copy source code
COPY . .

# Build with placeholder token — replaced at runtime by entrypoint
ENV VITE_BASE_PATH=/__DSB_BP__
RUN npm run build

# Production stage
FROM ${DOCKER_REGISTRY}/nginx:1.27.0-alpine

COPY --from=builder /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/nginx.conf
COPY entrypoint.sh /docker-entrypoint.d/99-dsb-base-path.sh

RUN chmod +x /docker-entrypoint.d/99-dsb-base-path.sh

EXPOSE 80
