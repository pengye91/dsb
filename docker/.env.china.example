# docker/.env.china.example
# China Region Configuration
# Users in China should set their own mirror here if needed, or use a public mirror service
DOCKER_REGISTRY=docker.io

# Microsoft Container Registry mirror (for Playwright E2E runner image)
# MCR_REGISTRY=<your-mcr-mirror>

PYPI_MIRROR=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_MIRROR=https://registry.npmmirror.com
CARGO_REGISTRY=sparse+https://mirrors.tuna.tsinghua.edu.cn/crates.io-index/
DEBIAN_MIRROR=mirrors.tuna.tsinghua.edu.cn
# Rust toolchain (Tsinghua rustup mirror — see https://mirrors.tuna.tsinghua.edu.cn/help/rustup/)
RUSTUP_DIST_SERVER=https://mirrors.tuna.tsinghua.edu.cn/rustup
RUSTUP_UPDATE_ROOT=https://mirrors.tuna.tsinghua.edu.cn/rustup/rustup

# Ports match default
DSB_SERVER_PORT=8080
DSB_DASHBOARD_PORT=3001
DSB_SSH_GATEWAY_PORT=2223
DSB_SEARXNG_PORT=8888
