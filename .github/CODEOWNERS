# CODEOWNERS — auto-assigns reviewers when a PR touches the listed paths.
# Each line is: <pattern>  <@github-handle or @org/team>
# See https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Default owners — fall through to the maintainers team for anything not
# covered by a more specific rule below.
/  @dsb/maintainers

# Core server
/src/api/         @dsb/server-reviewers
/src/core/        @dsb/server-reviewers
/src/docker/      @dsb/server-reviewers
/src/k8s/         @dsb/server-reviewers
/src/db/          @dsb/server-reviewers
/src/config/      @dsb/server-reviewers
/Cargo.toml
/Cargo.lock

# Auth & security surface
/src/auth/        @dsb/security-reviewers
/src/api/auth.rs  @dsb/security-reviewers
/src/api/errors.rs @dsb/security-reviewers
/src/session_token.rs @dsb/security-reviewers

# MCP server
/dsb-mcp-server/  @dsb/mcp-reviewers

# SSH gateway
/ssh-gateway/     @dsb/ssh-reviewers

# Dashboard
/dashboard/       @dsb/dashboard-reviewers

# Python SDK
/sdks/python/     @dsb/python-sdk-reviewers

# Deployment
/deployment/      @dsb/ops-reviewers
/docker/          @dsb/ops-reviewers
/docker-compose*.yml  @dsb/ops-reviewers
/Dockerfile       @dsb/ops-reviewers

# Documentation
/docs/            @dsb/docs-reviewers
/*.md             @dsb/docs-reviewers
/.github/         @dsb/maintainers

# Build / CI
/Makefile         @dsb/ops-reviewers
/.github/workflows/ @dsb/ops-reviewers
/rust-toolchain.toml @dsb/ops-reviewers

# Test infrastructure
/tests/common/    @dsb/server-reviewers
/dsb-agent-tester/ @dsb/mcp-reviewers
