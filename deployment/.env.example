# =============================================================================
# DSB Deployment Configuration (.env)
# =============================================================================
# This file configures Docker orchestration (ports, images, volumes).
# For application settings (API keys, timeouts), see dsb.yaml.
# =============================================================================

# -----------------------------------------------------------------------------
# Image Registry
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=docker.io
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Host Port Mappings
# -----------------------------------------------------------------------------
# Dashboard is the single entry point. All traffic (API, MCP, VNC, terminal)
# is proxied internally by the dashboard's nginx.
#
# Behind a reverse proxy (e.g. nginx): set to 80
# On local machine: set to 3880 (or any port above 1024)
#
# dsb-server and dsb-mcp-server are NOT exposed to the host —
# they are only accessible through the dashboard nginx.
DSB_DASHBOARD_HOST_PORT=3001
DSB_SSH_GATEWAY_HOST_PORT=2223
DSB_SEARXNG_HOST_PORT=8888

# -----------------------------------------------------------------------------
# Base Path (for reverse proxy with URL prefix stripping)
# -----------------------------------------------------------------------------
# When deploying behind a reverse proxy that strips a URL prefix
# set DSB_BASE_PATH to that prefix.
#
# This is a RUNTIME setting — no rebuild required. Change it and restart.
#
# Examples:
#   DSB_BASE_PATH=/           Standalone deployment (default)
DSB_BASE_PATH=/

# -----------------------------------------------------------------------------
# Data Volumes
# -----------------------------------------------------------------------------
# Host bind mount root — all persistent data is stored here.
# Each service uses a subdirectory: postgres/, static-files/, searxng/
# Data survives 'docker compose down -v' and 'docker volume prune'.
DSB_VOLUME_ROOT=/root/dsb-volumes

# Optional: Bind mounts (uncomment to use host paths instead of named volumes)
# POSTGRES_HOST_PATH=/opt/dsb/postgres
# STATIC_FILES_HOST_PATH=/opt/dsb/static-files

# -----------------------------------------------------------------------------
# HTTP Proxy (for enterprise networks with restricted internet access)
# -----------------------------------------------------------------------------
# Set these ONLY if your deployment runs behind an enterprise HTTP proxy.
# Leave all values empty (or remove the lines) if no proxy is needed.
#
# Both lowercase and uppercase variants are required because different tools
# inside containers respect different cases (e.g., curl uses lowercase,
# Python requests uses uppercase).
#
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1,
# http_proxy=http://proxy.example.com:3128
# https_proxy=http://proxy.example.com:3128
# no_proxy=localhost,127.0.0.1,
# AWS_DEFAULT_REGION=us-west-2
HTTP_PROXY=
HTTPS_PROXY=
http_proxy=
https_proxy=
NO_PROXY=
no_proxy=
AWS_DEFAULT_REGION=

# -----------------------------------------------------------------------------
# SearXNG
# -----------------------------------------------------------------------------
# Secret key for SearXNG session encryption.
# Generate with: openssl rand -hex 24
# If empty, the value in searxng/settings.yml will be used.
SEARXNG_SECRET=
