# =============================================================================
# DSB Deployment Configuration - China Region (.env)
# =============================================================================
# Optimized for users in China with domestic mirrors.
# =============================================================================

# -----------------------------------------------------------------------------
# Image Registry (China mirror)
# -----------------------------------------------------------------------------
DOCKER_REGISTRY=docker.mirrors.sjtug.sjtu.edu.cn
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Host Port Mappings
# -----------------------------------------------------------------------------
DSB_SERVER_HOST_PORT=8080
DSB_DASHBOARD_HOST_PORT=3001
DSB_SSH_GATEWAY_HOST_PORT=2223
DSB_SEARXNG_HOST_PORT=8888

# -----------------------------------------------------------------------------
# Data Volumes
# -----------------------------------------------------------------------------
# Host bind mount root — all persistent data is stored here.
DSB_VOLUME_ROOT=/root/dsb-volumes
