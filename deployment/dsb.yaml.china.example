# =============================================================================
# DSB Application Configuration - China Region (dsb.yaml)
# =============================================================================

server:
  host: "0.0.0.0"
  port: 8080
  api_key: null
  admin_api_key: null
  require_auth: true
  session_token_ttl_secs: 300

database:
  host: "postgres"
  port: 5432
  name: "dsb"
  user: "postgres"
  password: null
  pool_max_size: 10

docker:
  # China-accessible registry
  registry: "docker.mirrors.sjtug.sjtu.edu.cn"
  host: "unix:///var/run/docker.sock"
  default_image: "dsb/sandbox:latest"
  test_image: "python:3.12"

sandbox:
  default_inactivity_timeout: 30
  cleanup_dry_run: false
  state_monitor_interval: 60
  deleted_sandbox_retention_days: 15
  vnc_port: 5901
  default_vnc_resolution: "2560x1440"

  tool_timeouts:
    default_secs: 60
    web_tools_secs: 90
    browser_tools_secs: 120
    databend_tools_secs: 60
    http_buffer_secs: 30
    max_allowed_secs: 300

ssh:
  port: 2222
  api_url: "http://dsb-server:8080"
  api_key: null
  cleanup_check_interval: 30
  session_timeout: 300
  termination_timeout: 60

static_server:
  base_path: "/var/lib/dsb/static-files"

  # REQUIRED for Docker Compose deployments: the host path matching the bind mount
  # in docker-compose.yml (${DSB_VOLUME_ROOT}/static-files:/var/lib/dsb/static-files).
  # Without this, sandbox containers get bind mounts to the wrong host path and
  # files written by sandboxes won't be visible to the DSB server.
  host_path: "/root/dsb-volumes/static-files"

  max_file_size_mb: 100
  sandbox_upload_max_file_size_mb: 10
  enable_directory_browsing: false
  enable_zip_download: true
  max_zip_size_mb: 500
  zip_download_file_prefix: "sandbox-"

logging:
  level: "info"
  format: "json"
  ansi: false
